{
  "entities": {
    "Subscriber": {
      "title": "Subscriber",
      "description": "A person who joined the Inner Circle.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The subscriber's email address."
        },
        "name": {
          "type": "string",
          "description": "The subscriber's name."
        },
        "joinedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the subscriber joined."
        }
      },
      "required": ["email", "name", "joinedAt"]
    }
  },
  "firestore": {
    "subscribers/{subscriberId}": {
      "schema": "Subscriber",
      "description": "Collection of all Inner Circle subscribers."
    }
  }
}
